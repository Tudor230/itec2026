# Public URL (no trailing slash)
PUBLIC_APP_URL=https://app.example.com

# Postgres
POSTGRES_DB=itec2026
POSTGRES_USER=itec
POSTGRES_PASSWORD=replace-with-strong-password

# Server auth verification (Auth0)
AUTH0_DOMAIN=your-tenant.eu.auth0.com
AUTH0_AUDIENCE=https://itec2026-api
# Optional explicit issuer; defaults to https://<AUTH0_DOMAIN>/
AUTH0_ISSUER=

# Optional local JWT verification fallback (leave empty in Auth0-only prod)
AUTH_JWT_HS256_SECRET=
AUTH_JWT_ISSUER=
AUTH_JWT_AUDIENCE=
AUTH_JWT_PUBLIC_KEY=

# AI provider (optional)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_MS=30000
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Client Auth0 values
VITE_AUTH0_DOMAIN=your-tenant.eu.auth0.com
VITE_AUTH0_CLIENT_ID=replace-with-client-id
VITE_AUTH0_ROLES_CLAIM=https://itec2026-api/roles
VITE_ALLOWED_HOSTS=app.example.com
