generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id           String   @id
  name         String
  ownerSubject String?  @map("owner_subject")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  files        File[]
  members      ProjectMember[]
  invites      ProjectInvite[]

  @@index([ownerSubject, updatedAt])
  @@map("projects")
}

model File {
  id           String   @id
  projectId    String   @map("project_id")
  path         String
  content      String   @default("")
  ownerSubject String?  @map("owner_subject")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, path])
  @@index([ownerSubject, projectId, updatedAt])
  @@map("files")
}

model ProjectMember {
  id             String   @id
  projectId      String   @map("project_id")
  subject        String
  role           String
  addedBySubject String?  @map("added_by_subject")
  createdAt      DateTime @default(now()) @map("created_at")
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, subject])
  @@index([subject, createdAt])
  @@map("project_members")
}

model ProjectInvite {
  id               String    @id
  projectId        String    @map("project_id")
  tokenHash        String    @unique @map("token_hash")
  role             String
  createdBySubject String    @map("created_by_subject")
  expiresAt        DateTime  @map("expires_at")
  consumedAt       DateTime? @map("consumed_at")
  consumedBySubject String?  @map("consumed_by_subject")
  revokedAt        DateTime? @map("revoked_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  project          Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([expiresAt])
  @@map("project_invites")
}
