# Server
PORT=4000
CLIENT_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/itec2026

# Auth validation for API/JWT
AUTH_JWT_HS256_SECRET=replace-with-strong-secret
AUTH_JWT_ISSUER=https://your-tenant.us.auth0.com/
AUTH_JWT_AUDIENCE=https://your-api-identifier

# File/blob storage
FILES_STORAGE_ROOT=.data/files

# Persistent project workspace (mounted into Docker terminal sandbox)
# For dedicated dind daemon, use shared path like /data/workspaces
COLLAB_WORKSPACE_ROOT=.data/workspaces
COLLAB_WORKSPACE_MAX_SYNC_FILE_BYTES=500000
COLLAB_WORKSPACE_EXCLUDED_DIRS=node_modules,.git,dist,build,.next,coverage,.cache
COLLAB_WORKSPACE_LIVE_SYNC_DEBOUNCE_MS=500
COLLAB_WORKSPACE_LIVE_SYNC_POLL_MS=1000

# Docker terminal sandbox
COLLAB_DOCKER_SOCKET_PATH=
# Optional (dedicated daemon container): DOCKER_HOST=tcp://dockerd:2375
# Optional (local host daemon): DOCKER_HOST=tcp://127.0.0.1:2375
# Optional: DOCKER_TLS_VERIFY=1
COLLAB_DOCKER_LOG_LEVEL=info
COLLAB_TERMINAL_DOCKER_IMAGE=node:20-alpine
COLLAB_TERMINAL_DOCKER_AUTO_PULL=true
COLLAB_TERMINAL_DOCKER_UID=1000
COLLAB_TERMINAL_DOCKER_GID=1000
COLLAB_TERMINAL_DOCKER_CPU=1.0
COLLAB_TERMINAL_DOCKER_MEMORY=512m
COLLAB_TERMINAL_DOCKER_PIDS_LIMIT=128
COLLAB_TERMINAL_COMMAND_TIMEOUT_MS=120000
